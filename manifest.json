{
  "manifest_version": 3,
  "name": "Rapid View for ChatGPT",
  "version": "0.1.0",
  "description": "Locally virtualizes long ChatGPT conversations to keep the DOM lightweight in Chrome.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "offscreen"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Rapid View for ChatGPT",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/shared/settings.js",
        "src/content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
